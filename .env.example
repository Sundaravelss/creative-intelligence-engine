# =====================================================================
# Creative Intelligence Engine — environment template
# Copy to `.env` and fill in real values. Never commit secrets.
# =====================================================================

# === LLM (sponsor: Pioneer fine-tune) ===
# Get a key + the fine-tune model id from your Pioneer dashboard.
# https://api.pioneer.ai is OpenAI-compatible (Authorization: Bearer + X-API-Key both accepted).
PIONEER_API_KEY=
PIONEER_BASE_URL=https://api.pioneer.ai/v1
LLM_MARKETING_MODEL_ID=                             # Pioneer fine-tune model id (UUID)

# === LLM fallback: OpenAI ===
# Used when Pioneer rate-limits or errors. Standard OpenAI Python SDK.
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o-mini
OPENAI_MODEL_HERO=gpt-4o

# === LLM fallback: Claude (via the local `claude` CLI) ===
# Uses the same Anthropic auth your `claude` Code CLI has. Just install the CLI:
#   https://claude.com/claude-code  (then run `claude` once to authenticate)
CLAUDE_CODE_CLI_PATH=claude

# === LLM fallback: Hermes-CLI (nousresearch/hermes-agent → wraps Claude with skills/memory) ===
# Hermes CLI install: https://github.com/NousResearch/hermes-agent
# Configure once with `hermes setup` then `hermes model claude-cli` so it routes through your Claude CLI.
HERMES_CLI_PATH=hermes
# Optional: override the model Hermes uses per call. Leave empty to use `hermes config`'s default.
HERMES_CLI_MODEL=
HERMES_CLI_TIMEOUT_SEC=120

# === LLM fallback: Together AI (open-source models) ===
# Generic Together-compatible endpoint. Useful for Nous-Hermes hosted weights, Mixtral, Llama-3, etc.
HERMES_API_BASE=https://api.together.xyz/v1
HERMES_API_KEY=
HERMES_MODEL=NousResearch/Hermes-4-70B

# === Agent backend selection ===
# DEFAULT_ADAPTER: one of pioneer | openai | claude_code | hermes_cli | together
#   pioneer       — sponsor fine-tune (recommended default for the demo)
#   openai        — gpt-4o family
#   claude_code   — local `claude` CLI (Anthropic auth)
#   hermes_cli    — nousresearch/hermes-agent CLI (wraps Claude with skills/memory)
#   together      — Together AI / open-source models
#
# ADAPTER_FALLBACK_CHAIN: comma-separated names. Runtime tries them in order; the
# first to return a non-zero exit_code OR raise is skipped. The user never sees
# an "adapter X is missing" error as long as ONE adapter in the chain is healthy.
# To disable an adapter entirely, leave its API key blank — the runtime will
# raise NotConfigured and advance silently to the next adapter.
DEFAULT_ADAPTER=pioneer
ADAPTER_FALLBACK_CHAIN=pioneer,openai,claude_code,hermes_cli,together

# === Image / Video gen ===
FAL_KEY=
FAL_DEFAULT_IMAGE_MODEL=fal-ai/flux/dev
FAL_DEFAULT_VIDEO_MODEL=fal-ai/sora-2

# === Research ===
TAVILY_API_KEY=
# Set to `httpx` to force the offline brand-scan path (no Tavily call).
BRAND_SCAN_FALLBACK=

# === App ===
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8100
NEXT_PUBLIC_API_BASE_URL=http://localhost:8100
NODE_ENV=development

# === Variants ===
# 1-3, controls fan-out cost in the Art Director node.
VARIANTS_PER_SHOT=3
